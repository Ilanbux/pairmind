{
  "name": "pairmind",
  "version": "0.1.0",
  "description": "Launch AI co-creation sessions inside isolated git worktrees.",
  "type": "module",
  "packageManager": "bun@1.3.1",
  "bin": {
    "pairmind": "./bin/pairmind.ts"
  },
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test:coverage",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov && node scripts/check-coverage.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
